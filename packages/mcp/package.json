{
  "name": "@geowirehq/mcp",
  "version": "0.1.3",
  "mcpName": "io.github.geowire/geowire",
  "description": "GeoWire MCP server — search_places, get_place, geocode_address, reverse_geocode, list_geo_providers",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "geowire-mcp": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@geowirehq/core": "workspace:*",
    "@geowirehq/schema": "workspace:*",
    "@geowirehq/provider-sdk": "workspace:*",
    "@geowirehq/provider-nominatim": "workspace:*",
    "@geowirehq/provider-google": "workspace:*",
    "@geowirehq/provider-internal": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
