{
  "name": "geowire",
  "version": "0.1.0",
  "description": "GeoWire CLI — zero-config geo API server, one-shot search, provider setup wizard",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "geowire": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@geowire/core": "workspace:*",
    "@geowire/schema": "workspace:*",
    "@geowire/provider-sdk": "workspace:*",
    "@geowire/provider-nominatim": "workspace:*",
    "@geowire/provider-google": "workspace:*",
    "@geowire/provider-internal": "workspace:*",
    "@geowire/server": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
